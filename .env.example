# Copy this file to .env for local development. Never commit .env.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-local-secret
AUTH_EMAIL_FROM=Roundtable <noreply@roundtable.local>
AUTH_EMAIL_SERVER=smtp://localhost:1025

# Postgres
POSTGRES_USER=roundtable
POSTGRES_PASSWORD=roundtable
POSTGRES_DB=roundtable
POSTGRES_PORT=5432
DATABASE_URL=postgres://roundtable:roundtable@localhost:5432/roundtable

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Mailhog, optional. Start with: docker compose --profile mail up -d
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Workspace and logs
WORKSPACE_ROOT=./workspaces
HANDOFF_LOG_PATH=./ai-logs/handoffs.local.jsonl

# External services
E2B_API_KEY=

# Orchestrator LLM
# Default production path:
ROUNDTABLE_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Local DeepSeek comparison path:
# ROUNDTABLE_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash

# Local MiniMax comparison path:
# ROUNDTABLE_LLM_PROVIDER=minimax
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic/v1
# MINIMAX_MODEL=MiniMax-M3

# Local OpenAI comparison path:
# ROUNDTABLE_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Second coding-agent platform — Codex CLI (spec 020, adapter in src/adapters/codex).
# Bind any role to Codex once the `codex` CLI is installed:
# ROUNDTABLE_ADAPTER_REVIEWER=codex
# ROUNDTABLE_CODEX_COMMAND=codex
# ROUNDTABLE_CODEX_MODEL=
