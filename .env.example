# Copy this file to .env for local development. Never commit .env.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-local-secret
AUTH_EMAIL_FROM=Roundtable <noreply@roundtable.local>
AUTH_EMAIL_SERVER=smtp://localhost:1025

# Postgres
POSTGRES_USER=roundtable
POSTGRES_PASSWORD=roundtable
POSTGRES_DB=roundtable
POSTGRES_PORT=5432
DATABASE_URL=postgres://roundtable:roundtable@localhost:5432/roundtable

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Mailhog, optional. Start with: docker compose --profile mail up -d
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Workspace and logs
WORKSPACE_ROOT=./workspaces
HANDOFF_LOG_PATH=./ai-logs/handoffs.local.jsonl

# External services
E2B_API_KEY=
