{
  "name": "roundtable",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "setup": "docker compose up -d && pnpm db:migrate && pnpm db:seed",
    "dev:services": "docker compose up -d",
    "dev:services:mail": "docker compose --profile mail up -d",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:reset": "docker compose down -v && docker compose up -d && pnpm db:migrate && pnpm db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "spec:lint": "node scripts/spec-lint.mjs",
    "check:console": "node scripts/check-console-log.mjs"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^10.4.0",
    "lint-staged": "^17.0.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.0.5"
  },
  "packageManager": "pnpm@9.0.0",
  "simple-git-hooks": {
    "pre-commit": "corepack pnpm lint-staged && corepack pnpm typecheck && corepack pnpm check:console"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix"
  }
}
