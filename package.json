{
  "name": "roundtable",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "setup": "docker compose up -d && pnpm db:migrate && pnpm db:seed",
    "dev:services": "docker compose up -d",
    "dev:services:mail": "docker compose --profile mail up -d",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:reset": "docker compose down -v && docker compose up -d && pnpm db:migrate && pnpm db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "orch:smoke": "tsx scripts/orchestrator-smoke.ts",
    "demo:restore": "tsx scripts/demo-restore.ts",
    "dev:seed": "tsx scripts/dev-seed.ts",
    "sandbox:reap": "tsx scripts/sandbox-reap.ts",
    "checkpoints:cleanup": "tsx scripts/cleanup-checkpoints.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "spec:lint": "node scripts/spec-lint.mjs",
    "check:console": "node scripts/check-console-log.mjs",
    "ui:dev": "next dev",
    "ui:build": "next build",
    "ui:start": "next start"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "ai": "^6.0.191",
    "drizzle-orm": "^0.45.2",
    "e2b": "^2.27.0",
    "next": "^15.1.0",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "superjson": "^2.2.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "lint-staged": "^17.0.5",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.0.5"
  },
  "packageManager": "pnpm@9.0.0",
  "simple-git-hooks": {
    "pre-commit": "corepack pnpm lint-staged && corepack pnpm typecheck && corepack pnpm check:console"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix"
  }
}
