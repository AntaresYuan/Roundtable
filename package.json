{
  "name": "roundtable",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "docker compose up -d && pnpm db:migrate && pnpm db:seed",
    "dev:services": "docker compose up -d",
    "dev:services:mail": "docker compose --profile mail up -d",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:reset": "docker compose down -v && docker compose up -d && pnpm db:migrate && pnpm db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "packageManager": "pnpm@9.0.0"
}
